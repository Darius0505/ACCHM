  "project": {
    "name": "ACCHM ERP",
    "description": "Commercial ERP system for Vietnamese market",
    "type": "web-app",
    "status": "in-development",
    "target_market": "Vietnam SME to Enterprise"
  },
  "tech_stack": {
    "frontend": {
      "framework": "Next.js 13.5",
      "ui": "Tailwind CSS + Custom Components",
      "i18n": "next-intl (VN, EN, JA, KO)"
    },
    "backend": {
      "runtime": "Node.js",
      "framework": "Next.js API Routes"
    },
    "database": {
      "type": "SQL Server",
      "orm": "Prisma 5.22",
      "container": "Docker (acchm-sql)"
    },
    "hosting": {
      "planned": "Vercel / Azure"
    }
  },
  "database_schema": {
    "tables": [
      "Company",
      "FiscalYear",
      "AccountingPeriod",
      "Account",
      "Partner",
      "BankAccount",
      "Journal",
      "JournalEntry",
      "JournalEntryLine",
      "CashReceipt",
      "CashPayment",
      "BankTransaction",
      "Invoice",
      "InvoiceLine",
      "Payment",
      "PaymentAllocation",
      "User",
      "AuditLog"
    ],
    "key_features": [
      "Multi-company support",
      "Fiscal year with period close workflow (OPEN → SOFT_CLOSED → HARD_CLOSED → LOCKED)",
      "Chart of Accounts (TT200 Vietnamese standard)",
      "Multi-language support (nameEN, nameJP, nameOther)",
      "Soft delete with deletedAt",
      "Audit trail"
    ]
  },
  "api_endpoints": {
    "planned": [
      "/api/accounts - Chart of Accounts CRUD",
      "/api/journals - Journal CRUD",
      "/api/journal-entries - Journal Entry CRUD & Post",
      "/api/cash-receipts - Cash Receipt CRUD & Post",
      "/api/cash-payments - Cash Payment CRUD & Post",
      "/api/invoices - Invoice CRUD & Post",
      "/api/customers - Customer CRUD",
      "/api/vendors - Vendor CRUD",
      "/api/reports/* - Financial Reports"
    ],
    "implemented": []
  },
  "business_rules": [
    "Journal entry must balance (Total Debit = Total Credit)",
    "Cannot edit/delete posted entries",
    "Cannot post to closed period",
    "Fiscal year close requires all periods closed",
    "Invoice creates automatic journal entry on post"
  ],
  "features": {
    "phase_01": {
      "name": "Database Schema",
      "status": "complete",
      "items": [
        "18 database models",
        "172 Chart of Accounts (TT200)",
        "12 Accounting Periods",
        "7 Default Journals"
      ]
    },
    "phase_02": {
      "name": "Core Accounting (Journal/GL)",
