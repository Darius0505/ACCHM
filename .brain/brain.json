    },
    "phase_03": {
      "name": "Cash & Bank Management",
      "status": "pending"
    },
    "phase_04": {
      "name": "Accounts Receivable",
      "status": "pending"
    },
    "phase_05": {
      "name": "Accounts Payable",
      "status": "pending"
    },
    "phase_06": {
      "name": "Financial Reports",
      "status": "pending"
    },
    "phase_07": {
      "name": "System & Security",
      "status": "pending"
    },
    "phase_08": {
      "name": "Testing & Polish",
      "status": "pending"
    }
  },
  "knowledge_items": {
    "patterns": [
      "UUID for primary keys, document numbers for human-readable IDs",
      "onDelete: NoAction, onUpdate: NoAction to avoid SQL Server cyclic cascade issues",
      "Document numbers format: PREFIX-YYYY-NNNNN (e.g., GJ-2026-00001)"
    ],
    "gotchas": [
      "SQL Server requires explicit NoAction for cyclic references",
      "Prisma migrate dev needs interactive mode in terminal",
      "Use prisma db push for non-interactive environments"
    ],
    "conventions": [
      "Multi-language: name (VN), nameEN, nameJP, nameOther",
      "Status workflow: DRAFT → POSTED → CANCELLED",
      "Period close: OPEN → SOFT_CLOSED → HARD_CLOSED"
    ]
  }
}